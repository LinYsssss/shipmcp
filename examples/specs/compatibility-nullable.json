{
  "openapi": "3.1.0",
  "info": {
    "title": "Compatibility Nullable JSON API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://compat-json.example"
    }
  ],
  "paths": {
    "/compat": {
      "post": {
        "operationId": "createCompatPayload",
        "summary": "Create compatibility payload",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "displayName": {
                    "type": ["string", "null"]
                  },
                  "labels": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "metrics": {
                    "type": "object",
                    "properties": {
                      "stable": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created."
          }
        }
      }
    }
  }
}
