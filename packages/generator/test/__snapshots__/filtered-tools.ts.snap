import { z } from "zod";

export type GeneratedTool = {
  name: string;
  method: string;
  path: string;
  description: string;
  inputSchema: Record<string, z.ZodTypeAny>;
  buildRequest: (input: Record<string, unknown>) => {
    path: string;
    query: URLSearchParams;
    headers: Record<string, string>;
    body?: unknown;
  };
};

export const generatedTools: GeneratedTool[] = [
  {
    name: "list_pets",
    method: "GET",
    path: "/pets",
    description: "List pets",
    inputSchema: {
      limit: z.number().int().optional()
    },
    buildRequest(input) {
      const query = new URLSearchParams();
      const headers: Record<string, string> = {};
      let body: unknown = undefined;
      const resolvedPath = `/pets`;
      if (input.limit !== undefined) query.set("limit", String(input.limit));


      return {
        path: resolvedPath,
        query,
        headers,
        body
      };
    }
  },

  {
    name: "get_pet",
    method: "GET",
    path: "/pets/{petId}",
    description: "Get a pet by ID",
    inputSchema: {
      petId: z.string(),
      includeVisits: z.boolean().optional()
    },
    buildRequest(input) {
      const query = new URLSearchParams();
      const headers: Record<string, string> = {};
      let body: unknown = undefined;
      const resolvedPath = `/pets/${encodeURIComponent(String(input.petId))}`;
      if (input.includeVisits !== undefined) query.set("includeVisits", String(input.includeVisits));


      return {
        path: resolvedPath,
        query,
        headers,
        body
      };
    }
  }
];
